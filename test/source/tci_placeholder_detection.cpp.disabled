/**
 * @file tci_placeholder_detection.cpp.disabled
 * @brief Tests to detect placeholder implementations (DISABLED)
 *
 * This file is disabled because placeholder implementations have been removed.
 * To re-enable: rename to .cpp (API has been updated, should work as-is)
 */

#include <doctest/doctest.h>
#include <tci/tci.h>
#include <cytnx.hpp>
#include <cmath>

TEST_CASE("Placeholder Detection Tests") {
    tci::context_handle_t<cytnx::Tensor> ctx;
    tci::create_context(ctx);

    SUBCASE("EQ Function Placeholder Detection") {
        // Create two different tensors with same shape but different values
        tci::shape_t<cytnx::Tensor> shape = {2, 2};
        cytnx::Tensor zeros, ones;

        tci::zeros(ctx, shape, zeros);
        tci::fill(ctx, shape, cytnx::cytnx_complex128(1.0, 0.0), ones);

        // These tensors have same shape but different values
        // A proper eq function should return false
        bool are_equal = tci::eq(ctx, zeros, ones);

        // If eq is a placeholder (only checks shapes), this will fail
        INFO("EQ function should return false for tensors with different values");
        INFO("If this fails, eq function is likely a placeholder");
        CHECK(are_equal == false);

        // Test with identical tensors
        cytnx::Tensor zeros2;
        tci::zeros(ctx, shape, zeros2);
        bool are_identical = tci::eq(ctx, zeros, zeros2);
        CHECK(are_identical == true);
    }

    SUBCASE("SVD Function Placeholder Detection") {
        // Create a simple 2x2 identity matrix
        cytnx::Tensor identity;
        tci::eye(ctx, 2, identity);

        cytnx::Tensor u, v_dag;
        tci::real_ten_t<cytnx::Tensor> s_diag;

        tci::svd(ctx, identity, 1, u, s_diag, v_dag);

        // Check if all outputs are identical to input (placeholder behavior)
        bool u_same_as_input = tci::eq(ctx, u, identity);
        bool s_same_as_input = tci::eq(ctx, s_diag, identity);
        bool v_same_as_input = tci::eq(ctx, v_dag, identity);

        INFO("SVD outputs should be different from input matrix");
        INFO("If all outputs are identical to input, SVD is likely a placeholder");

        // At least one output should be different from input
        bool at_least_one_different = !(u_same_as_input && s_same_as_input && v_same_as_input);
        CHECK(at_least_one_different == true);
    }

    SUBCASE("Norm Function Behavior Verification") {
        // Test norm of zeros matrix (should be 0)
        tci::shape_t<cytnx::Tensor> shape = {2, 2};
        cytnx::Tensor zeros;
        tci::zeros(ctx, shape, zeros);

        auto norm_zeros = tci::norm(ctx, zeros);
        INFO("Norm of zeros matrix should be 0.0");
        CHECK(std::abs(norm_zeros) < 1e-10);

        // Test norm of ones matrix (should be 2.0 for 2x2)
        cytnx::Tensor ones;
        tci::fill(ctx, shape, cytnx::cytnx_complex128(1.0, 0.0), ones);

        auto norm_ones = tci::norm(ctx, ones);
        INFO("Norm of 2x2 ones matrix should be 2.0");
        CHECK(std::abs(norm_ones - 2.0) < 1e-10);

        // Test norm of identity matrix (should be sqrt(2) for 2x2)
        cytnx::Tensor identity;
        tci::eye(ctx, 2, identity);

        auto norm_identity = tci::norm(ctx, identity);
        INFO("Norm of 2x2 identity matrix should be sqrt(2)");
        CHECK(std::abs(norm_identity - std::sqrt(2.0)) < 1e-10);
    }

    SUBCASE("Get Element Function Verification") {
        // Create a 2x2 zeros matrix and set specific values
        tci::shape_t<cytnx::Tensor> shape = {2, 2};
        cytnx::Tensor tensor;
        tci::zeros(ctx, shape, tensor);

        // Set element (0,0) to (2.5, 1.5)
        tci::elem_coors_t<cytnx::Tensor> coord_00 = {0, 0};
        cytnx::cytnx_complex128 test_value(2.5, 1.5);
        tci::set_elem(ctx, tensor, coord_00, test_value);

        // Get element back
        auto retrieved_value = tci::get_elem(ctx, tensor, coord_00);

        INFO("Get_elem should return the exact value that was set");
        INFO("If this fails with (1.0, 0.0), get_elem is likely a placeholder");
        CHECK(std::abs(retrieved_value.real() - 2.5) < 1e-10);
        CHECK(std::abs(retrieved_value.imag() - 1.5) < 1e-10);

        // Test another coordinate to ensure it's still zero
        tci::elem_coors_t<cytnx::Tensor> coord_01 = {0, 1};
        auto zero_value = tci::get_elem(ctx, tensor, coord_01);
        CHECK(std::abs(zero_value.real() - 0.0) < 1e-10);
        CHECK(std::abs(zero_value.imag() - 0.0) < 1e-10);
    }

    tci::destroy_context(ctx);
}